# NutriVision AI - Environment Configuration
# Copy this file to .env and update with your actual values

# ==============================================
# BASIC APPLICATION SETTINGS
# ==============================================

# Flask Application Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_DEBUG=True
FLASK_TESTING=False

# Database Configuration
DATABASE_PATH=nutrition_analyzer.db

# ==============================================
# AI INTEGRATION SETTINGS
# ==============================================

# Google Gemini AI API Key (Required)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyCSnIMEi-SpHrc8zjEAkODm8H-FGpnBU8E

# ==============================================
# AUTHENTICATION & SECURITY SETTINGS
# ==============================================

# Session Security (Set to True in production with HTTPS)
SESSION_COOKIE_SECURE=False

# Guest User Limits
GUEST_ANALYSIS_LIMIT=1

# ==============================================
# EMAIL SETTINGS (Optional - for future features)
# ==============================================

# SMTP Configuration for email verification/password reset
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ==============================================
# DEPLOYMENT SETTINGS
# ==============================================

# Server Port
PORT=5000

# ==============================================
# OPTIONAL ADVANCED SETTINGS
# ==============================================

# Rate Limiting
REQUESTS_PER_MINUTE=20
REQUESTS_PER_HOUR=100
REQUESTS_PER_DAY=500

# File Upload Limits
MAX_FILE_SIZE=16777216

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO